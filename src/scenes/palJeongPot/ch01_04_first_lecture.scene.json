    {
      "type": "MONOLOGUE",
      "speaker": "구윤모",
      "text": "옆자리 사람한테 무슨 짓이야.",
      "subtype": "self_aware"
    },
    {
      "type": "MONOLOGUE",
      "speaker": "구윤모",
      "text": "정신 차려라 구윤모. 너 이정도로 정신나간 여미새는 아니잖아.",
      "subtype": "self_aware"
    },
    {
      "type": "CHARACTER",
      "id": "윤모",
      "sprite": "default",
      "position": "center",
      "transition": "fade"
    },
    {
      "type": "BGM",
