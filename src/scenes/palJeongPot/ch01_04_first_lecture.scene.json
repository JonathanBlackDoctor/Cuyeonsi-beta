      "volume": 0.5,
      "fade": 1
    },
    {
      "type": "MONOLOGUE",
      "speaker": "구윤모",
      "text": "노트북만 보자.",
      "subtype": "recover"
    },
    {
      "type": "MONOLOGUE",
      "speaker": "구윤모",
      "text": "카데바 안내 다시 정리.",
