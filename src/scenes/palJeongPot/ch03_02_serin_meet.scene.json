{
  "id": "ch03_02_serin_meet",
  "commands": [
    {
      "type": "BG",
      "image": "bg_dongsan_lobby"
    },
    {
      "type": "NARRATION",
      "text": "윤모가 화장실 갔다 길을 잃는다."
    },
    {
      "type": "CHARACTER",
      "id": "윤모",
      "sprite": "default",
      "position": "center",
      "transition": "fade"
    },
    {
      "type": "BG",
      "image": "bg_dongsan_hallway",
      "transition": "fade"
    },
    {
      "type": "NARRATION",
      "text": "의국 복도. 옆 사무실에서 흰 가운의 여자가 차트를 들고 나온다. 부딪힐 뻔하다."
    },
    {
      "type": "CHARACTER",
      "id": "차세린",
      "sprite": "default",
      "position": "right",
      "transition": "fade"
    },
    {
      "type": "VIDEO",
      "src": "video_meet_serin"
    },
    {
      "type": "DIALOGUE",
      "speaker": "차세린",
      "text": "...아."
    },
    {
      "type": "DIALOGUE",
      "speaker": "구윤모",
      "text": "죄송합니다, 길을 잃어서요."
    },
    {
      "type": "DIALOGUE",
      "speaker": "차세린",
      "text": "견학생이죠?"
    },
    {
      "type": "CG",
      "image": "cg_serin_first_meet",
      "cgId": "cg_serin_first_meet"
    },
    {
      "type": "NARRATION",
      "text": "차세린. 흰 가운 안 청록 스크럽, 미디엄 헤어. 부드러운 미소에 옅은 피로."
    },
    {
      "type": "CG_HIDE"
    },
    {
      "type": "BGM",
      "track": "bgm_comic",
      "volume": 0.4,
      "fade": 1
    },
    {
      "type": "CHARACTER",
      "id": "윤모",
      "sprite": "perv",
      "position": "center",
      "transition": "fade"
    },
    {
      "type": "MONOLOGUE",
      "speaker": "구윤모",
      "text": "...어. 가운 안에 청록 스크럽.",
      "subtype": "perv_start"
    },
    {
      "type": "MONOLOGUE",
      "speaker": "구윤모",
      "text": "누나가 야간 당직 끝나고 의국 소파에서 잠들어 계시는 모습을 보게 된다면...",
      "subtype": "perv_start"
    },
    {
      "type": "MONOLOGUE",
      "speaker": "구윤모",
      "text": "어른스러운 표정이 풀어진 모습을 처음 보게 될 수도.",
      "subtype": "perv_start"
    },
    {
      "type": "CHARACTER",
      "id": "윤모",
      "sprite": "recover",
      "position": "center",
      "transition": "fade"
    },
    {
      "type": "MONOLOGUE",
      "speaker": "구윤모",
      "text": "아 진짜. 처음 본 사람 앞에서 뭐 하냐.",
      "subtype": "self_aware"
    },
    {
      "type": "MONOLOGUE",
      "speaker": "구윤모",
      "text": "누나는 일하러 가시는 분이고, 너는 길 잃은 견학생.",
      "subtype": "self_aware"
    },
    {
      "type": "MONOLOGUE",
      "speaker": "구윤모",
      "text": "정신 차려라 구윤모.",
      "subtype": "self_aware"
    },
    {
      "type": "CHARACTER",
      "id": "윤모",
      "sprite": "default",
      "position": "center",
      "transition": "fade"
    },
    {
      "type": "BGM",
      "track": "bgm_daily",
      "volume": 0.5,
      "fade": 1
    },
    {
      "type": "MONOLOGUE",
      "speaker": "구윤모",
      "text": "길 묻기. 정중하게.",
      "subtype": "recover"
    },
    {
      "type": "DIALOGUE",
      "speaker": "차세린",
      "text": "학생? 괜찮아요?"
    },
    {
      "type": "DIALOGUE",
      "speaker": "구윤모",
      "text": "아, 죄송합니다. 견학 중에 길을 잘못 들었습니다."
    },
    {
      "type": "DIALOGUE",
      "speaker": "차세린",
      "text": "의국 복도까지 들어왔으면 잘못 든 게 맞네요. 단체는 병동 쪽이에요. 같이 가요."
    },
    {
      "type": "DIALOGUE",
      "speaker": "구윤모",
      "text": "감사합니다."
    },
    {
      "type": "CHOICE",
      "choices": [
        {
          "text": "공부 열심히 할게요",
          "next": "ch03_02b_serious",
          "tone": "mature_serious",
          "isKey": true,
          "descriptor": "ch3_first_intro"
        },
        {
          "text": "오늘 견학 잘 부탁드립니다",
          "next": "ch03_02b_casual",
          "tone": "warm_supportive"
        }
      ]
    }
